<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - Mock Trial Hub</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page">
      <header class="page-header">
        <h1>Admin</h1>
        <a class="back" href="/">Back</a>
      </header>

      <div class="admin-layout">
        <aside class="admin-left">
          <section class="panel">
            <h2>Rooms</h2>
            <form class="inline-form" method="post" action="/admin/room">
              <input name="roomNumber" placeholder="Room number" aria-label="Room number" required />
              <button type="submit">Add</button>
            </form>
            <% if (rooms.length === 0) { %>
              <p class="empty">No rooms added yet.</p>
            <% } else { %>
              <ul class="room-list">
                <% rooms.forEach((r) => { %>
                  <li class="list-row">
                    <span><%= r.label %></span>
                    <form method="post" action="/admin/room/delete">
                      <input type="hidden" name="roomId" value="<%= r.id %>" />
                      <button type="submit" class="delete-button">Delete</button>
                    </form>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </section>

          <section class="panel">
            <h2>Competition</h2>
            <% if (teams.length < 2) { %>
              <p class="empty">Add at least two teams to start.</p>
            <% } else { %>
              <form id="startCompetitionForm" method="post" action="/admin/start">
                <button id="startCompetitionButton" type="submit">Start Competition</button>
                <p id="startCompetitionMessage" class="confirm-message"></p>
              </form>
            <% } %>
          </section>
        </aside>

        <aside class="admin-middle">
          <form class="panel" method="post" action="/admin/school">
            <h2>Add School</h2>
            <label>
              School name
              <input name="schoolName" required />
            </label>
            <button type="submit">Add School</button>
          </form>

          <section class="panel">
            <h2>Judges</h2>
            <form class="inline-form" method="post" action="/admin/judge">
              <input name="judgeName" placeholder="Judge name" aria-label="Judge name" required />
              <button type="submit">Create Pin</button>
            </form>
            <% if (judges.length === 0) { %>
              <p class="empty">No judges added yet.</p>
            <% } else { %>
              <ul class="judge-list">
                <% judges.forEach((j) => { %>
                  <li class="list-row">
                    <span><strong><%= j.name %></strong> - <%= j.pin %></span>
                    <form method="post" action="/admin/judge/delete">
                      <input type="hidden" name="judgeId" value="<%= j.id %>" />
                      <button type="submit" class="delete-button">Delete</button>
                    </form>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </section>
        </aside>

        <section class="panel admin-main">
          <h2>Schools & Teams</h2>
          <% if (schools.length === 0) { %>
            <p class="empty">No schools added yet.</p>
          <% } else { %>
            <ul class="school-list">
              <% schools.forEach((s) => { %>
                <li class="school-item">
                  <div class="list-row">
                    <strong><%= s.name %></strong>
                    <form method="post" action="/admin/school/delete">
                      <input type="hidden" name="schoolId" value="<%= s.id %>" />
                      <button type="submit" class="delete-button">Delete</button>
                    </form>
                  </div>
                  <% if (s.teams.length === 0) { %>
                    <p class="empty">No teams yet.</p>
                  <% } else { %>
                    <ul class="team-list">
                      <% s.teams.forEach((t) => { %>
                        <li class="list-row">
                          <span><%= t.name %> (<%= t.code %>)</span>
                          <form method="post" action="/admin/team/delete">
                            <input type="hidden" name="teamId" value="<%= t.id %>" />
                            <button type="submit" class="delete-button">Delete</button>
                          </form>
                        </li>
                      <% }) %>
                    </ul>
                  <% } %>
                  <form class="team-add-form" method="post" action="/admin/team">
                    <input type="hidden" name="schoolId" value="<%= s.id %>" />
                    <div class="team-add-row">
                      <input name="teamName" placeholder="Add team" required />
                      <button type="submit" class="icon-button" aria-label="Add team">+</button>
                    </div>
                  </form>
                </li>
              <% }) %>
            </ul>
          <% } %>
        </section>
      </div>
    </main>
    <script src="/admin.js"></script>
  </body>
</html>
